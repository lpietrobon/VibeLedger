# === Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=
PLAID_USE_MOCK=true

# === App
APP_BASE_URL=http://localhost:8000
TOKEN_ENCRYPTION_KEY=

# Required: bearer token for API authentication.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VIBELEDGER_API_TOKEN=

# Optional: auto-sync all active items every N hours. Disabled by default (0).
# Set to 24 for daily, 6 for every 6 hours, etc.
SYNC_INTERVAL_HOURS=0

# Optional: comma-separated allowed Host header values.
# ALLOWED_HOSTS=vibeledger.tail1234.ts.net

# Optional: automate opening/closing a short-lived Tailscale Funnel path for connect.
CONNECT_TUNNEL_AUTOMATION=0
CONNECT_TUNNEL_STRICT=1
